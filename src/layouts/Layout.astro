---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Calendario de tareas - Organiza tus actividades diarias con etiquetas, repeticiones y recordatorios." />
    <meta name="theme-color" content="#6366f1" />
    <meta property="og:title" content="Calendario de Tareas" />
    <meta property="og:description" content="Organiza tus actividades diarias con etiquetas, repeticiones y recordatorios." />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Calendario de Tareas" />
    <meta name="twitter:description" content="Organiza tus actividades diarias con etiquetas, repeticiones y recordatorios." />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" /><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin /><link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet" />
    <title>Calendario de Tareas</title>
</head>
<body>
    <div class="max-w-6xl mx-auto px-4 py-8">
        <slot />
    </div>
    <script src="../scripts/calendar.ts"></script>
    <script is:inline>
      // Only register service worker in production (not dev mode with Vite)
      if ("serviceWorker" in navigator && location.hostname !== "localhost") {
        navigator.serviceWorker.register("/sw.js");
      }
    </script>
</body>
</html>

