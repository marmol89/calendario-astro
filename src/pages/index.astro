---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CalendarPanel from '../components/CalendarPanel.astro';
import Sidebar from '../components/Sidebar.astro';
import Modals from '../components/Modals.astro';
---

<Layout>
  <Header />
  <div class="layout-grid gap-8">
    <CalendarPanel />
    <Sidebar />
  </div>
  <Modals />
  <nav class="mobile-nav md:hidden fixed bottom-0 left-0 right-0 bg-card border-t border-slate flex justify-around items-center py-2 px-1 z-40 safe-bottom">
    <button onclick="changeView(-1)" class="flex flex-col items-center gap-0.5 text-secondary hover:text-primary transition-colors p-1" data-i18n-aria="nav.previous">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span class="text-[10px] font-medium" data-i18n="nav.previous">Ant</span>
    </button>
    <button onclick="resetToToday()" class="flex flex-col items-center gap-0.5 text-secondary hover:text-primary transition-colors p-1">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      <span class="text-[10px] font-medium" data-i18n="nav.today">Hoy</span>
    </button>
    <button onclick="openModal()" class="flex flex-col items-center gap-0.5 text-indigo-500 hover:text-indigo-600 transition-colors p-1">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/></svg>
      <span class="text-[10px] font-medium" data-i18n="btn.newTask">+ Tarea</span>
    </button>
    <button onclick="changeView(1)" class="flex flex-col items-center gap-0.5 text-secondary hover:text-primary transition-colors p-1" data-i18n-aria="nav.next">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-[10px] font-medium" data-i18n="nav.next">Sig</span>
    </button>
  </nav>
</Layout>
