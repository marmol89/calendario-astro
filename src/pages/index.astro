---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CalendarPanel from '../components/CalendarPanel.astro';
import Sidebar from '../components/Sidebar.astro';
import Modals from '../components/Modals.astro';
---

<Layout>
  <Header />
  <CalendarPanel />
  <Sidebar />
  <Modals />

  <!-- FAB -->
  <button onclick="openModal()" class="fab" data-i18n-aria="btn.newTask.label">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
  </button>

  <!-- Bottom Nav -->
  <nav class="bottom-nav md:hidden">
    <button data-i18n-aria="nav.previous" onclick="changeView(-1)">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7"/></svg>
      <span>Ant</span>
    </button>
    <button onclick="resetToToday()">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
      <span>Hoy</span>
    </button>
    <button class="active" onclick="openModal()">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
      <span>Nueva</span>
    </button>
    <button onclick="toggleDarkMode()">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
      <span>Tema</span>
    </button>
    <button onclick="changeView(1)">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
      <span>Sig</span>
    </button>
  </nav>
</Layout>
