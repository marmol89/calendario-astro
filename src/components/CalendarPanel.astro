<div class="bg-card overflow-hidden" id="calendarPanel" style="margin:0 12px;border-radius:12px;border:1px solid var(--border-color)">
  <div class="day-headers" id="dayHeaders">
    <div data-i18n="day.mon">Lun</div>
    <div data-i18n="day.tue">Mar</div>
    <div data-i18n="day.wed">Mié</div>
    <div data-i18n="day.thu">Jue</div>
    <div data-i18n="day.fri">Vie</div>
    <div data-i18n="day.sat">Sáb</div>
    <div data-i18n="day.sun">Dom</div>
  </div>
  <div id="calendarGrid" class="calendar-grid"></div>
  <div id="dayView" class="hidden day-view"></div>
</div>
