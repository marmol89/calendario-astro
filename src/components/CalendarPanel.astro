<div class="bg-card rounded-2xl shadow-sm border border-slate overflow-hidden" id="calendarPanel">
  <div class="grid grid-cols-7 border-b border-slate text-center text-xs font-semibold text-secondary uppercase tracking-wider" style="background-color: var(--accent-light);" id="dayHeaders">
    <div class="py-3" data-i18n="day.mon">Lun</div>
    <div class="py-3" data-i18n="day.tue">Mar</div>
    <div class="py-3" data-i18n="day.wed">Mié</div>
    <div class="py-3" data-i18n="day.thu">Jue</div>
    <div class="py-3" data-i18n="day.fri">Vie</div>
    <div class="py-3" data-i18n="day.sat">Sáb</div>
    <div class="py-3" data-i18n="day.sun">Dom</div>
  </div>
  <div id="calendarGrid" class="calendar-grid"></div>
  <div id="dayView" class="hidden" style="max-height:600px;overflow-y:auto;"></div>
</div>
