<!-- Compact mobile-first header -->
<div class="compact-header">
  <button onclick="changeView(-1)" class="nav-btn" data-i18n-aria="nav.previous">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7"/></svg>
  </button>
  <h1 id="monthDisplay" class="text-primary">Mayo 2026</h1>
  <button onclick="changeView(1)" class="nav-btn" data-i18n-aria="nav.next">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
  </button>
  <button onclick="resetToToday()" class="today-btn" data-i18n="nav.today">Hoy</button>
  <button id="darkModeToggle" onclick="toggleDarkMode()" class="nav-btn" data-i18n-aria="nav.darkMode">
    <svg id="sunIcon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
    <svg id="moonIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/></svg>
  </button>
  <span class="flex items-center gap-1 px-1 text-xs text-secondary" title="Sync">
    <svg id="syncIcon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:#94a3b8"><path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
  </span>
</div>

<!-- Search bar -->
<div class="search-bar">
  <div style="position:relative">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-secondary)"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
    <input type="text" id="searchInput" oninput="debouncedRender()" data-i18n-placeholder="search.placeholder" data-i18n-aria="search.label" placeholder="Buscar tareas...">
  </div>
</div>

<!-- Tools row -->
<div class="tools-row">
  <button onclick="setView('month')" id="btnMonthView" style="background:var(--accent);color:white;border-color:var(--accent)">Mes</button>
  <button onclick="setView('week')" id="btnWeekView">Semana</button>
  <button onclick="setView('day')" id="btnDayView">Día</button>
  <button onclick="toggleShowCompleted()" id="btnFilterCompleted">✓ Completadas</button>
  <button onclick="openTagManager()">🏷️ Etiquetas</button>
  <button onclick="exportTasks()">📤 Exportar</button>
  <button onclick="exportICal()" class="hide-xs">📅 iCal</button>
  <button onclick="document.getElementById('importFile').click()">📥 Importar</button>
  <button onclick="showShortcutsModal()" class="hide-xs">⌨️</button>
  <button id="btnNotify" onclick="toggleNotifications()">🔔</button>
  <button id="btnLangToggle">EN/ES</button>
  <input type="file" id="importFile" accept=".json" class="hidden" />
</div>
