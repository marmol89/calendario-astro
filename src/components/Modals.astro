<!-- Task Modal -->
<div id="taskModal" role="dialog" aria-modal="true" aria-labelledby="modalTitle" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4">
  <div class="bg-card rounded-2xl shadow-xl w-full max-w-md overflow-hidden modal-enter" id="taskModalContent">
    <div class="p-6 border-b border-slate">
      <h3 id="modalTitle" class="text-xl font-bold text-primary" data-i18n="modal.task.new">Añadir nueva tarea</h3>
    </div>
    <form id="taskForm" class="p-6 space-y-4">
      <div>
        <label class="block text-sm font-medium text-secondary mb-1" data-i18n="form.title">Título</label>
        <input type="text" id="taskTitle" required class="w-full px-4 py-2 border border-slate rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-card text-primary">
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-medium text-secondary mb-1" data-i18n="form.date">Fecha</label>
          <input type="date" id="taskDate" required class="w-full px-4 py-2 border border-slate rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-card text-primary">
        </div>
        <div>
          <label class="block text-sm font-medium text-secondary mb-1" data-i18n="form.time">Hora</label>
          <input type="time" id="taskTime" class="w-full px-4 py-2 border border-slate rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-card text-primary">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-secondary mb-1" data-i18n="form.repeat">Repetir</label>
        <select id="taskRepeat" class="w-full px-4 py-2 border border-slate rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-card text-primary">
          <option value="none" data-i18n="repeat.none">No Repetir</option>
          <option value="daily" data-i18n="repeat.daily">Diario</option>
          <option value="weekly" data-i18n="repeat.weekly">Semanal</option>
          <option value="monthly" data-i18n="repeat.monthly">Mensual</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-secondary mb-1" data-i18n="form.priority">Prioridad</label>
        <select id="taskPriority" class="w-full px-4 py-2 border border-slate rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-card text-primary">
          <option value="high">🔴 Alta</option>
          <option value="medium" selected>🟡 Media</option>
          <option value="low">🟢 Baja</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-secondary mb-1" data-i18n="form.description">Descripción</label>
        <textarea id="taskDesc" rows="3" class="w-full px-4 py-2 border border-slate rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none transition-all bg-card text-primary"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-secondary mb-2" data-i18n="form.tag">Etiqueta</label>
        <div class="flex gap-2 flex-wrap" id="tagPicker"></div>
      </div>
      <div class="flex items-center gap-2">
        <input type="checkbox" id="taskCompleted" class="w-4 h-4 text-indigo-600 rounded focus:ring-indigo-500">
        <label for="taskCompleted" class="text-sm text-secondary" data-i18n="form.completed">Marcar como completada</label>
      </div>
      <div class="flex gap-3 pt-4">
        <button type="button" onclick="closeModal()" class="flex-1 px-4 py-2 border border-slate text-secondary rounded-lg hover:bg-subtle font-medium transition-all" data-i18n="modal.task.cancel">Cancelar</button>
        <button type="submit" class="flex-1 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium shadow-md transition-all" data-i18n="modal.task.save">Guardar</button>
      </div>
    </form>
  </div>
</div>

<!-- Detail Modal -->
<div id="detailModal" role="dialog" aria-modal="true" aria-labelledby="detailTitle" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4">
  <div class="bg-card rounded-2xl shadow-xl w-full max-w-md overflow-hidden modal-enter" id="detailModalContent">
    <div class="p-6 border-b border-slate">
      <h3 id="detailTitle" class="text-xl font-bold text-primary">Detalles</h3>
    </div>
    <div id="detailModalBody" class="p-6"></div>
    <div class="p-6 border-t border-slate flex gap-3 justify-end">
      <button onclick="editCurrentTask()" id="editBtn" class="px-4 py-2 border border-slate text-secondary rounded-lg hover:bg-subtle font-medium transition-all" data-i18n="modal.detail.edit">Editar</button>
      <button onclick="closeDetailModal()" class="px-4 py-2 bg-subtle text-secondary rounded-lg hover:bg-hover font-medium transition-all" data-i18n="modal.detail.close">Cerrar</button>
    </div>
  </div>
</div>

<!-- Tag Manager Modal -->
<div id="tagManagerModal" role="dialog" aria-modal="true" aria-labelledby="tagManagerTitle" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4">
  <div class="bg-card rounded-2xl shadow-xl w-full max-w-md overflow-hidden modal-enter" id="tagManagerContent">
    <div class="p-6 border-b border-slate">
      <h3 id="tagManagerTitle" class="text-xl font-bold text-primary" data-i18n="tag.manager">Gestionar Etiquetas</h3>
    </div>
    <div class="p-6 space-y-4">
      <div class="flex gap-2">
        <input type="text" id="newTagName" data-i18n-placeholder="tag.name" class="flex-1 px-3 py-2 border border-slate rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none bg-card text-primary text-sm">
        <input type="color" id="newTagColor" value="#6366f1" class="w-10 h-10 rounded border border-slate cursor-pointer">
        <button onclick="addTag()" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 text-sm font-medium" data-i18n="tag.add">Añadir</button>
      </div>
      <div id="tagList" class="space-y-2 max-h-60 overflow-y-auto"></div>
    </div>
    <div class="p-6 border-t border-slate flex justify-end">
      <button onclick="closeTagManager()" class="px-4 py-2 bg-subtle text-secondary rounded-lg hover:bg-hover font-medium transition-all" data-i18n="modal.tags.close">Cerrar</button>
    </div>
  </div>
</div>

<!-- Keyboard Shortcuts Modal -->
<div id="shortcutsModal" role="dialog" aria-modal="true" aria-labelledby="shortcutsTitle" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm hidden flex items-center justify-center z-50 p-4">
  <div class="bg-card rounded-2xl shadow-xl w-full max-w-sm overflow-hidden modal-enter" id="shortcutsContent">
    <div class="p-6 border-b border-slate">
      <h3 id="shortcutsTitle" class="text-xl font-bold text-primary" data-i18n="modal.shortcuts.title">Atajos de Teclado</h3>
    </div>
    <div class="p-6 space-y-3">
      <div class="flex justify-between items-center text-sm"><span data-i18n="shortcuts.prev">Periodo anterior</span><kbd class="px-2 py-1 bg-subtle rounded text-xs font-mono text-primary">←</kbd></div>
      <div class="flex justify-between items-center text-sm"><span data-i18n="shortcuts.next">Periodo siguiente</span><kbd class="px-2 py-1 bg-subtle rounded text-xs font-mono text-primary">→</kbd></div>
      <div class="flex justify-between items-center text-sm"><span data-i18n="shortcuts.today">Ir a hoy</span><kbd class="px-2 py-1 bg-subtle rounded text-xs font-mono text-primary">T</kbd></div>
      <div class="flex justify-between items-center text-sm"><span data-i18n="shortcuts.new">Nueva tarea</span><kbd class="px-2 py-1 bg-subtle rounded text-xs font-mono text-primary">N</kbd></div>
      <div class="flex justify-between items-center text-sm"><span data-i18n="shortcuts.close">Cerrar modal</span><kbd class="px-2 py-1 bg-subtle rounded text-xs font-mono text-primary">Esc</kbd></div>
      <div class="flex justify-between items-center text-sm"><span>Deshacer</span><kbd class="px-2 py-1 bg-subtle rounded text-xs font-mono text-primary">Ctrl+Z</kbd></div>
      <div class="flex justify-between items-center text-sm"><span>Rehacer</span><kbd class="px-2 py-1 bg-subtle rounded text-xs font-mono text-primary">Ctrl+Shift+Z</kbd></div>
      <div class="flex justify-between items-center text-sm"><span data-i18n="shortcuts.help">Mostrar esta ayuda</span><kbd class="px-2 py-1 bg-subtle rounded text-xs font-mono text-primary">?</kbd></div>
    </div>
    <div class="p-6 border-t border-slate flex justify-end">
      <button onclick="closeShortcutsModal()" class="px-4 py-2 bg-subtle text-secondary rounded-lg hover:bg-hover font-medium transition-all" data-i18n="modal.detail.close">Cerrar</button>
    </div>
  </div>
</div>
